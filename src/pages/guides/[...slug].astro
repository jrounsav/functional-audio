---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const guidesEntries = await getCollection('library');
  return guidesEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { 
  title, 
  description, 
  category, 
  targetState, 
  formula, 
  scientificReferences = [] 
} = entry.data;
---

<Layout title={`${title.split(':')[0]} - Sound Guide`} description={description}>
  <div class="article-page">
    <div class="container">
      <!-- Back Link -->
      <a href="/guides" class="back-link">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Guides
      </a>

      <!-- Article Header -->
      <header class="article-header">
        <span class="category-badge">{category}</span>
        <h1>{title}</h1>
        <p class="article-subtitle">{description}</p>
      </header>

      <div class="article-grid">
        <!-- Main Content -->
        <article class="article-body">
          <Content />
        </article>

        <!-- Sidebar / Meta Card -->
        <aside class="article-sidebar">
          <div class="glass-card sticky-card">
            <h3>Acoustic Profile</h3>
            
            <div class="spec-item">
              <span class="spec-label">Target Mindstate</span>
              <span class="spec-value text-gradient">{targetState}</span>
            </div>

            {formula && (
              <div class="spec-item">
                <span class="spec-label">Spectral Profile</span>
                <span class="spec-value formula-code"><code>{formula}</code></span>
              </div>
            )}

            <!-- Citations -->
            {scientificReferences.length > 0 && (
              <div class="citations-section">
                <h4>Sources & References</h4>
                <p class="citations-intro">References mentioned in this guide:</p>
                <ul class="citations-list">
                  {scientificReferences.map((ref) => (
                    <li class="citation-item">
                      <div class="citation-meta">
                        <strong>"{ref.title}"</strong>
                        <span>{ref.author} ({ref.year})</span>
                        <em class="journal-tag">{ref.journal}</em>
                      </div>
                      {ref.url && (
                        <a href={ref.url} target="_blank" rel="noopener noreferrer" class="citation-btn">
                          Read Source
                          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                            <polyline points="15 3 21 3 21 9"></polyline>
                            <line x1="10" y1="14" x2="21" y2="3"></line>
                          </svg>
                        </a>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<style>
  .article-page {
    padding: 3rem 0 6rem 0;
  }

  /* Containers & Grids */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 2.5rem;
    transition: var(--transition-smooth);
  }

  .back-link:hover {
    color: var(--accent-cyan);
    transform: translateX(-4px);
  }

  .article-header {
    margin-bottom: 3.5rem;
    max-width: 850px;
  }

  .category-badge {
    background: rgba(0, 242, 254, 0.08);
    border: 1px solid rgba(0, 242, 254, 0.15);
    color: var(--accent-cyan);
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 1.25rem;
  }

  .article-header h1 {
    font-size: 3rem;
    line-height: 1.15;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .article-subtitle {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Grid Layout */
  .article-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .article-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* Article Body Typography styling */
  .article-body {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .article-body :global(h2) {
    font-size: 1.9rem;
    margin: 3rem 0 1.25rem 0;
    color: var(--text-primary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.5rem;
  }

  .article-body :global(h3) {
    font-size: 1.4rem;
    margin: 2rem 0 1rem 0;
    color: var(--text-primary);
  }

  .article-body :global(p) {
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
  }

  .article-body :global(p strong) {
    color: var(--text-primary);
  }

  .article-body :global(ul), .article-body :global(ol) {
    margin-bottom: 1.75rem;
    padding-left: 2rem;
    color: var(--text-secondary);
  }

  .article-body :global(li) {
    margin-bottom: 0.6rem;
  }

  /* Inline Code Styling */
  .article-body :global(code) {
    font-family: monospace;
    font-size: 0.9em;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    color: var(--accent-blue);
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  /* Blockquote / Alert callouts styling */
  .article-body :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.75rem;
    background: rgba(0, 242, 254, 0.02);
    border-left: 3px solid var(--accent-cyan);
    border-radius: 4px;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .article-body :global(blockquote p) {
    margin: 0;
  }

  .article-body :global(blockquote strong) {
    color: var(--accent-cyan);
  }

  /* Math/Formula representation styling */
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.95rem;
    background: rgba(13, 20, 38, 0.2);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .article-body :global(th), .article-body :global(td) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0.85rem 1rem;
    text-align: left;
  }

  .article-body :global(th) {
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Sidebar styling */
  .sticky-card {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2.5rem;
  }

  .sticky-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.75rem;
  }

  .spec-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .spec-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .spec-value {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .formula-code {
    background: rgba(255, 255, 255, 0.03);
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    font-family: monospace;
    font-size: 0.9rem;
    width: max-content;
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--accent-blue);
  }

  .citations-section {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1.5rem;
    margin-top: 0.5rem;
  }

  .citations-section h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .citations-intro {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .citations-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .citation-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .citation-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.85rem;
  }

  .citation-meta strong {
    color: var(--text-primary);
    line-height: 1.3;
  }

  .citation-meta span {
    color: var(--text-secondary);
  }

  .journal-tag {
    color: var(--accent-blue);
    font-size: 0.75rem;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 500;
  }

  .citation-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-cyan);
    align-self: flex-start;
    transition: var(--transition-smooth);
    border-bottom: 1px dashed rgba(0, 242, 254, 0.2);
    padding-bottom: 2px;
  }

  .citation-btn:hover {
    color: var(--text-primary);
    border-color: var(--text-primary);
  }

  /* Math Block Display */
  .article-body :global(.math-block) {
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--accent-cyan);
    background: rgba(13, 20, 38, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.75rem;
    border-radius: 12px;
    margin: 2.25rem 0;
    box-shadow: inset 0 0 15px rgba(0, 242, 254, 0.03);
    text-shadow: 0 0 12px rgba(0, 242, 254, 0.3);
  }

  @media (max-width: 640px) {
    .article-body :global(.math-block) {
      font-size: 1.3rem;
      padding: 1.25rem;
    }
  }
</style>
